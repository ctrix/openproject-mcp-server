# =============================================================================
# OpenProject MCP Server - Environment Variables
# =============================================================================

# --- Required (all modes) ---

# Base URL of your OpenProject instance
OPENPROJECT_URL=https://openproject.example.com

# --- Stdio mode (Claude Code desktop) ---
# Set OPENPROJECT_API_KEY to use API key authentication.
# This is the only auth method for stdio transport.

OPENPROJECT_API_KEY=your-api-key-here

# --- HTTP mode (OAuth 2.1, multi-user) ---
# All three variables below are required for HTTP transport.
# Register an OAuth application in OpenProject under
# Administration > Authentication > OAuth applications.

# OAUTH_CLIENT_ID=your-oauth-client-id
# OAUTH_CLIENT_SECRET=your-oauth-client-secret
# MCP_BASE_URL=http://localhost:8000

# --- Optional ---

# HTTP proxy for OpenProject API requests
# OPENPROJECT_PROXY=http://proxy.example.com:8080

# Disable SSL certificate verification (development only)
# OPENPROJECT_VERIFY_SSL=false

# Server host and port for HTTP mode
# MCP_HOST=127.0.0.1
# MCP_PORT=8000

# Log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO
